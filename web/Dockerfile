FROM caddy:2.11.2-alpine

COPY --chown=root:root Caddyfile /etc/caddy/Caddyfile
# Assume a tarball generated by CI
ADD frontend.tar.xz /srv/
RUN grep -q '^caddy:' /etc/group || addgroup -S caddy
RUN id -u caddy >/dev/null 2>&1 || adduser -S -D -H -G caddy caddy
RUN chown -R caddy:caddy /srv /data /config
USER caddy
